# ============================================================
# shiwake-ai-PR Agent  Environment Variables
# ============================================================

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL_DEFAULT=claude-sonnet-4-6
ANTHROPIC_MODEL_HEAVY=claude-opus-4-7

# --- Supabase ---
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_ANON_KEY=eyJ...
SUPABASE_STORAGE_BUCKET=visuals-bucket

# --- GitHub（Gitログ素材化用）---
GITHUB_TOKEN=ghp_...
GITHUB_REPO=nice-gecko/shiwake-ai

# --- X (Twitter) API --- ※Phase 1〜4 全て手動投稿のため不要
# X_API_KEY=
# X_API_SECRET=
# X_ACCESS_TOKEN=
# X_ACCESS_TOKEN_SECRET=
# X_BEARER_TOKEN=

# --- Meta (Threads + Instagram) ---
META_APP_ID=
META_APP_SECRET=
THREADS_USER_ID=
THREADS_ACCESS_TOKEN=
IG_BUSINESS_ACCOUNT_ID=
IG_ACCESS_TOKEN=

# --- 通知 ---
DISCORD_WEBHOOK_URL=                          # Discord Webhook URL

# --- shiwake-ai 本体との連携 ---
SHIWAKE_AI_WEBHOOK_SECRET=
SHIWAKE_AI_DEMO_USER_EMAIL=demo@shiwake-ai.com
SHIWAKE_AI_DEMO_USER_PASSWORD=

# --- 画像生成（Phase 2以降）---
IMAGE_GEN_PROVIDER=anthropic

# --- 承認ダッシュボード ---
DASHBOARD_BASE_URL=https://pr-agent-xxxxx.run.app
DASHBOARD_BASIC_AUTH_USER=dsk
DASHBOARD_BASIC_AUTH_PASS=

# --- 運用 ---
LOG_LEVEL=INFO
TIMEZONE=Asia/Tokyo
